# Kit (ConvertKit) V4 API key.
# Create one in your Kit account: Settings -> Developer -> "New API Key".
KIT_API_KEY=kit_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Defaults to https://api.kit.com/v4
# KIT_BASE_URL=https://api.kit.com/v4

# Safety switch for actually sending mail to subscribers.
#   false (default) -> send_broadcast refuses unless called with confirm=true
#   true            -> fully unattended sending; broadcasts go out with no prompt
KIT_AUTO_SEND=false

# Optional request timeout in seconds (default 30).
# KIT_REQUEST_TIMEOUT=30
